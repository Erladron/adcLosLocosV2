rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // HELPERS (Validaciones maestras)
    // =====================================================

    function isLogged() {
      return request.auth != null;
    }

    function currentUser() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function currentUserRole() {
      return currentUser() != null ? currentUser().tipo : null;
    }

    function isAdmin() {
      return currentUserRole() == 'administrador';
    }

    function isDirectiva() {
      return currentUserRole() == 'directiva';
    }

    function isSocio() {
      return currentUserRole() == 'socio';
    }

    function canManageUsers() {
      return isAdmin() || isDirectiva();
    }

    function canInvite() {
      return isAdmin() || isDirectiva() || isSocio();
    }

    function isPortero() {
      return currentUserRole() == 'portero';
    }

    function canScan() {
      return isAdmin() || isDirectiva() || isPortero();
    }

    function isOwnUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================
    // USERS (Gestión de usuarios y blindaje de roles)
    // =====================================================

    match /users/{userId} {

      // LECTURA INDIVIDUAL: Cualquier usuario logueado puede leer perfiles (para cargar nombres, etc.)
      allow get: if isLogged();

      // LISTADO FILTRADO POR ROL: 
      // 1. Admin y Directiva ven todo sin restricciones.
      // 2. Los Socios pueden listar directiva, socios e invitados (se veta que listen porteros).
      // 3. Invitados y Porteros no cumplen ninguna y se les deniega el acceso automáticamente.
      // 🚀 CORREGIDO: Ahora el portero también tiene autorización para hacer búsquedas y listar
      allow list: if canManageUsers() || isPortero() || (isSocio() && resource.data.tipo != 'portero');

      // CREACIÓN: Blindado con dos vías (Auto-registro de invitados vs Modo Directiva)
      allow create: if 
        (
          isOwnUser(userId)
          && request.resource.data.tipo == 'invitado'
          && request.resource.data.estado == 'pending_data'
        )
        || canManageUsers();

      // ACTUALIZACIÓN:
      allow update: if
        canManageUsers()
        ||
        (
          isOwnUser(userId)
          && resource.data.tipo == 'invitado'
          && resource.data.estado == 'pending_data'
          && request.resource.data.estado == 'pending_approval'
          && request.resource.data.tipo == resource.data.tipo
          && (!('dni' in request.resource.data) || request.resource.data.dni.size() <= 9)
        )
        ||
        (
          isOwnUser(userId)
          && resource.data.estado == 'active'
          && request.resource.data.tipo == resource.data.tipo
          && request.resource.data.estado == resource.data.estado
          && (!('dni' in request.resource.data) || request.resource.data.dni.size() <= 9)
        );

      allow delete: if isAdmin();

      // =====================================================
      // SUBCOLECCIÓN: TOKENS DE NOTIFICACIONES PUSH (FCM)
      // =====================================================
      match /tokens/{token} {
        allow read, write: if isOwnUser(userId) || canManageUsers();
      }
    }

    // =====================================================
    // INVITED USERS (Gestión de invitaciones)
    // =====================================================

    match /invitedUsers/{inviteId} {
      allow read: if isLogged();
      allow create: if canInvite();
      allow update, delete: if canManageUsers(); 
    }

    // =====================================================
    // EMAIL DE INVITACIÓN (Triggers)
    // =====================================================

    match /mail/{document=**} {
      allow create: if canInvite();
    }

    // =====================================================
    // EVENTS (Gestión de convocatorias y asistencia)
    // =====================================================

    match /events/{eventId} {
      allow read: if isLogged() || resource.data.isPrivate == false; 
      allow create, delete: if canManageUsers(); 
      allow update: if canManageUsers() || (
        isLogged() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeCount'])
      );

      match /attendance/{userId} {
        allow read: if isLogged(); 
        allow write: if isOwnUser(userId) || canManageUsers(); 
      }
    }

    // =====================================================
    // FAIR ACCESS (Control de Accesos y Pases de Feria)
    // =====================================================

    match /fair-access/{accessId} {
      
      allow read: if isLogged() && (
        resource.data.userId == request.auth.uid || 
        canInvite() || 
        canScan()
      ); 
      
      allow create: if canInvite() && 
        request.resource.data.hostId == request.auth.uid && 
        request.resource.data.scans.size() == 0; 

      allow update: if canScan() && 
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.date == resource.data.date &&
        request.resource.data.scans.size() == resource.data.scans.size() + 1; 

      allow delete: if isLogged() && (resource.data.hostId == request.auth.uid || canManageUsers());
    }
  }
}