rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // =====================================================
    // HELPERS
    // =====================================================

    function isLogged() {
      return request.auth != null;
    }

    function currentUser() {

      return exists(
        /databases/$(database)/documents/users/$(request.auth.uid)
      )

      ?

      get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data

      :

      null;

    }

    function currentUserRole() {

      return currentUser() != null

        ?

        currentUser().tipo

        :

        null;

    }

    function isAdmin() {
      return currentUserRole() == 'administrador';
    }

    function isDirectiva() {
      return currentUserRole() == 'directiva';
    }

    function isSocio() {
      return currentUserRole() == 'socio';
    }

    function canManageUsers() {

      return (
        isAdmin()
        ||
        isDirectiva()
      );

    }

    function canInvite() {

      return (
        isAdmin()
        ||
        isDirectiva()
        ||
        isSocio()
      );

    }

    function isOwnUser(userId) {

      return request.auth != null
        &&
        request.auth.uid == userId;

    }

    // =====================================================
    // USERS
    // =====================================================

    match /users/{userId} {

      allow read: if isLogged();

      allow create: if
        request.auth != null
        &&
        request.auth.uid == userId;

      allow update: if

        // ADMIN / DIRECTIVA
        canManageUsers()

        ||

        // ONBOARDING INVITADO
        (
          isOwnUser(userId)

          &&

          resource.data.tipo == 'invitado'

          &&

          resource.data.estado == 'pending_data'

          &&

          request.resource.data.estado == 'pending_approval'

          &&

          request.resource.data.tipo == resource.data.tipo
        )

        ||

        // USUARIO ACTIVO EDITANDO PERFIL
        (
          isOwnUser(userId)

          &&

          resource.data.estado == 'active'

          &&

          request.resource.data.tipo == resource.data.tipo

          &&

          request.resource.data.estado == resource.data.estado
        );

      allow delete: if isAdmin();

    }

    // =====================================================
    // INVITED USERS
    // =====================================================

    match /invitedUsers/{inviteId} {

      allow read: if true;

      // 🔥 CAMBIO IMPORTANTE
      allow create: if canInvite();

      allow update: if

        canManageUsers()

        ||

        isLogged();

      allow delete: if canManageUsers();

    }

    // =====================================================
    // EMAIL DE INVITACION
    // =====================================================

    match /mail/{document= **} {

      allow create: if canInvite();


    }
  }

}