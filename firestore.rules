rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // HELPERS (Validaciones maestras)
    // =====================================================

    function isLogged() {
      return request.auth != null;
    }

    function currentUser() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function currentUserRole() {
      return currentUser() != null ? currentUser().tipo : null;
    }

    function isAdmin() {
      return currentUserRole() == 'administrador';
    }

    function isDirectiva() {
      return currentUserRole() == 'directiva';
    }

    function isSocio() {
      return currentUserRole() == 'socio';
    }

    function canManageUsers() {
      return isAdmin() || isDirectiva();
    }

    function canInvite() {
      return isAdmin() || isDirectiva() || isSocio();
    }

    function isOwnUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================
    // USERS (Gestión de usuarios y blindaje de roles)
    // =====================================================

    match /users/{userId} {

      // LECTURA: Solo usuarios que pertenezcan a la app (logueados)
      allow read: if isLogged();

      // CREACIÓN: Blindado con dos vías (Auto-registro de invitados vs Modo Directiva)
      allow create: if 
        (
          isOwnUser(userId)
          && request.resource.data.tipo == 'invitado'
          && request.resource.data.estado == 'pending_data'
        )
        || canManageUsers();

      // ACTUALIZACIÓN:
      allow update: if
        // VÍA A: ADMIN / DIRECTIVA (Poder total de modificación)
        canManageUsers()
        ||
        // VÍA B: ONBOARDING INVITADO (Avanzando de estado y rellenando datos)
        (
          isOwnUser(userId)
          && resource.data.tipo == 'invitado'
          && resource.data.estado == 'pending_data'
          && request.resource.data.estado == 'pending_approval'
          && request.resource.data.tipo == resource.data.tipo
          && (!('dni' in request.resource.data) || request.resource.data.dni.size() <= 9)
        )
        ||
        // VÍA C: USUARIO ACTIVO EDITANDO PERFIL (Previene hackeo de roles y DNI largo)
        (
          isOwnUser(userId)
          && resource.data.estado == 'active'
          && request.resource.data.tipo == resource.data.tipo
          && request.resource.data.estado == resource.data.estado
          && (!('dni' in request.resource.data) || request.resource.data.dni.size() <= 9)
        );

      allow delete: if isAdmin();

      // =====================================================
      // SUBCOLECCIÓN: TOKENS DE NOTIFICACIONES PUSH (FCM)
      // =====================================================
      match /tokens/{token} {
        // Un socio maneja sus tokens, directiva puede consultarlos para envíos
        allow read, write: if isOwnUser(userId) || canManageUsers();
      }
    }

    // =====================================================
    // INVITED USERS (Gestión de invitaciones)
    // =====================================================

    match /invitedUsers/{inviteId} {
      allow read: if isLogged(); // Cerrado al público general de internet
      allow create: if canInvite();
      // Solo la directiva puede modificar, aprobar o borrar invitaciones ajenas
      allow update, delete: if canManageUsers(); 
    }

    // =====================================================
    // EMAIL DE INVITACIÓN (Triggers)
    // =====================================================

    match /mail/{document=**} {
      allow create: if canInvite();
    }
  }
}