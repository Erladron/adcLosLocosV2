{
  "name": "adcLosLocosV2",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "test": "ng test",
    "lint": "ng lint",
    "watch": "ng build --watch --configuration development",
    "start": "ionic serve",
    "start:desa": "ionic serve --configuration=desa",
    "emuladores": "cross-env FIREBASE_AUTH_EMULATOR_HOST=\"localhost:9099\" firebase emulators:start",
    "build:core": "ng build shared-core",
    "docs:global": "typedoc",
    "build:web:prod": "ng build web-onboarding --configuration=production",
    "build:app:prod": "ng build app --configuration=production",
    "build:android": "npm run build:core && ng build app && npx cap sync android && npx cap open android",
    "deploy:rules:desa": "firebase use desa && firebase deploy --only firestore:rules",
    "deploy:rules:prod": "firebase use prod && firebase deploy --only firestore:rules",
    "deploy:web:desa": "firebase use desa && npm run build:core && ng build web-onboarding && firebase deploy --only hosting",
    "deploy:web:prod": "firebase use prod && npm run build:core && npm run build:web:prod && firebase deploy --only hosting",
    "deploy:all:desa": "firebase use desa && npm run build:core && ng build web-onboarding && ng build app && cd functions && npm run build && cd .. && firebase deploy",
    "deploy:all:prod": "firebase use prod && npm run build:core && npm run build:web:prod && npm run build:app:prod && cd functions && npm run build && cd .. && firebase deploy",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@capacitor-community/barcode-scanner": "^4.0.1",
    "@capacitor/android": "^8.3.3",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/angular": "^8.0.0",
    "@mapbox/mapbox-gl-geocoder": "^5.1.2",
    "firebase": "^12.13.0",
    "html5-qrcode": "^2.3.8",
    "ionicons": "^7.0.0",
    "mapbox-gl": "^3.24.0",
    "ngx-image-cropper": "^9.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.25",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/schematics": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "^20.3.25",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/language-service": "^20.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.4.0",
    "@compodoc/compodoc": "^2.0.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.15.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "firebase-admin": "^14.0.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.2",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4"
  },
  "description": "Asociacion Deportiva Cultural Los Locos"
}
