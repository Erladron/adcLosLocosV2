<ion-card class="audit-card" data-cy="audit-form-card">

  <!-- ========================================= -->
  <!-- HEADER -->
  <!-- ========================================= -->

  <ion-card-header>

    <ion-card-title>

      Estado y Auditoría

    </ion-card-title>

  </ion-card-header>

  <!-- ========================================= -->
  <!-- CONTENT -->
  <!-- ========================================= -->

  <ion-card-content>

    <!-- ========================================= -->
    <!-- STATUS -->
    <!-- ========================================= -->

    <div class="status-container">

      <span class="status-label">

        Estado actual

      </span>

      <div class="status-pill" [ngClass]="user.estado" data-cy="audit-status-pill">

        <ion-icon *ngIf="isActive" name="checkmark-circle-outline">
        </ion-icon>

        <ion-icon *ngIf="isInactive" name="close-circle-outline">
        </ion-icon>

        <ion-icon *ngIf="isPending" name="time-outline">
        </ion-icon>

        <span data-cy="audit-status-text">
          {{ statusLabel }}
        </span>

      </div>

    </div>

    <!-- ========================================= -->
    <!-- ALTA -->
    <!-- ========================================= -->

    <div class="audit-modern-card" data-cy="audit-card-alta">

      <div class="audit-modern-title">

        <ion-icon name="person-add-outline">
        </ion-icon>

        <span>

          Alta usuario

        </span>

      </div>

      <div class="audit-modern-content">

        <div *ngIf="user.createdAt" class="audit-modern-line">

          <ion-icon name="time-outline">
          </ion-icon>

          <span data-cy="audit-alta-date">
            {{ user.createdAt?.toDate()
            | date:'dd/MM/yyyy · HH:mm' }}
          </span>

        </div>

        <div *ngIf="user.creadoPorNombre" class="audit-modern-line">

          <ion-icon name="person-outline">
          </ion-icon>

          <span data-cy="audit-alta-by">
            {{ user.creadoPorNombre }}
          </span>

        </div>

      </div>

    </div>

    <!-- ========================================= -->
    <!-- INVITACIÓN -->
    <!-- ========================================= -->

