        <ion-icon name="close-circle-outline">
        </ion-icon>

        <span>

          Baja usuario

        </span>

      </div>

      <div class="audit-modern-content">

        <div class="audit-modern-line">

          <ion-icon name="time-outline">
          </ion-icon>

