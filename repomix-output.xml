          <ion-input 
            [(ngModel)]="user.direccion" 
            (ngModelChange)="onDireccionChange($event)"
            (ionBlur)="ocultarSugerencias()"
            placeholder="Calle, número o localidad" 
            [readonly]="!canEdit || (isEditMode && !editing)"
            data-cy="input-profile-direccion">
          </ion-input>
        </ion-item>
        
        @if (mostrarSugerencias && sugerencias.length > 0) {
          <ion-list class="mapbox-suggestions" data-cy="profile-address-suggestions">
            @for (sug of sugerencias; track sug.id || sug.name) {
              <ion-item button (mousedown)="$event.preventDefault()" (click)="seleccionarDireccion(sug)" data-cy="profile-address-suggestion-item">
                <ion-label>
                  <h2 class="sug-title">{{ sug.name }}</h2>
                  <p class="sug-subtitle">{{ sug.place_formatted }}</p>
                </ion-label>
