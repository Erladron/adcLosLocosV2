<div class="section-card" data-cy="credentials-form-card">

  <div class="section-header">
    <div class="credentials-title">
      <h2>Credenciales</h2>
      <p>Acceso y seguridad del usuario.</p>
    </div>

    <div *ngIf="isEditMode && canEditCredentials && false" class="section-actions">
    </div>
  </div>

  <div class="form-fields">

    <!-- MODO FORMULARIO (ALTA / REGISTRO) -->
    <ng-container *ngIf="!isEditMode">
      <ion-item class="custom-item">
        <ion-label position="stacked">Email *</ion-label>
        <!-- 🔄 REPARADO: Notifica el cambio de email directamente al objeto user del padre -->
        <ion-input type="email" [ngModel]="user?.email" (ngModelChange)="user!.email = $event" autocomplete="off"
          data-cy="input-credentials-email">
        </ion-input>
      </ion-item>

      <ion-item class="custom-item">
        <ion-label position="stacked">Repetir Email *</ion-label>
        <!-- 🔄 MANTENEMOS: La solución que ya te detecta el repetir email perfectamente -->
        <ion-input type="email" [ngModel]="repeatEmail"
          (ngModelChange)="repeatEmail = $event; repeatEmailChange.emit($event)" autocomplete="off"
          data-cy="input-credentials-repeat-email">
        </ion-input>
      </ion-item>

      <ion-item class="custom-item">
        <ion-label position="stacked">Contraseña *</ion-label>
        <ion-input [type]="mostrarPassword ? 'text' : 'password'" [ngModel]="password"
          (ngModelChange)="passwordChange.emit($event)" autocomplete="new-password"
          data-cy="input-credentials-password"> </ion-input>
        <ion-button fill="clear" slot="end" (click)="onTogglePassword()" data-cy="btn-credentials-toggle-password">
          <ion-icon [name]="mostrarPassword ? 'eye-off-outline' : 'eye-outline'"></ion-icon>
        </ion-button>
      </ion-item>

      <ion-item class="custom-item">
        <ion-label position="stacked">Repetir Contraseña *</ion-label>
        <ion-input [type]="mostrarRepeatPassword ? 'text' : 'password'" [ngModel]="repeatPassword"
          (ngModelChange)="repeatPasswordChange.emit($event)" autocomplete="new-password"
          data-cy="input-credentials-repeat-password"> </ion-input>
        <ion-button fill="clear" slot="end" (click)="onToggleRepeatPassword()"
          data-cy="btn-credentials-toggle-repeat-password">
          <ion-icon [name]="mostrarRepeatPassword ? 'eye-off-outline' : 'eye-outline'"></ion-icon>
        </ion-button>
      </ion-item>
    </ng-container>

    <!-- MODO LECTURA / EDICIÓN -->
    <ng-container *ngIf="isEditMode">
      <ion-item class="custom-item readonly-item">
        <ion-label position="stacked">Email de acceso</ion-label>
        <ion-input type="email" [(ngModel)]="user.email" [readonly]="true"
          data-cy="input-credentials-readonly-email"></ion-input>
      </ion-item>

      <div class="reset-password-container" *ngIf="isOwnProfile || canEditCredentials">
        <p class="info-text">
          <ion-icon name="lock-closed-outline"></ion-icon>
          La contraseña se gestiona mediante un enlace seguro.
        </p>

        <ion-button expand="block" class="reset-btn" (click)="onSendLink()" data-cy="btn-credentials-reset-password">
          <ion-icon slot="start" name="send-outline"></ion-icon>
          Cambiar Contraseña
        </ion-button>
      </div>

      <div class="password-helper" *ngIf="!isOwnProfile && !canEditCredentials"
        style="margin-top: 16px; color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; padding-left: 4px;">
        La contraseña solo puede ser modificada por el propio usuario o un administrador.
      </div>
    </ng-container>

  </div>
</div>
