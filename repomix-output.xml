  width: 6px;
}
.mapbox-suggestions::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4px;
}

.mapbox-suggestions ion-item {
  --background: transparent;
  --border-color: rgba(255, 255, 255, 0.08); /* Líneas separadoras sutiles */
  --padding-start: 16px;
  --padding-end: 16px;
  --min-height: 56px;
}

.mapbox-suggestions ion-item:last-child {
  --border-width: 0;
}

/* Tipografía de las sugerencias */
.sug-title {
  color: #ffffff;
  font-weight: 600;
  font-size: 0.95rem;
  margin-bottom: 4px;
}

.sug-subtitle {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.8rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========================================================
   BADGE DEL DNI
======================================================== */
.dni-badge {
  font-size: 1.15rem;
  font-weight: 700;
