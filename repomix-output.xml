  --background: linear-gradient(180deg, #123d92 0%, #0d327c 100%) !important;
  position: relative;
  
  .background-logo {
    position: fixed;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
