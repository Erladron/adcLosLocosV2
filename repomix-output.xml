<app-page-header title="Mis Pases Digitales" [showMenu]="true" [showBack]="true" data-cy="page-header"></app-page-header>

<ion-content fullscreen="true" class="home-content" data-cy="fair-page-content">
  
  <div class="background-logo">
    <img src="assets/img/escudo.png" alt="Escudo" class="small-escudo-bg">
  </div>

  <div class="home-container">

    <div class="fair-theme-title" data-cy="fair-theme-title">
      <ion-icon name="sparkles-outline"></ion-icon>
      <span>PASES VÁLIDOS PARA HOY</span>
      <ion-icon name="qr-code-outline"></ion-icon>
    </div>

    <div class="events-list-container" *ngIf="misPasesHoy.length > 0; else sinPasesTpl">
      
      <div *ngFor="let pase of misPasesHoy" 
           class="stadium-membership-card fair-style-card card-spacer" 
           [ngClass]="{'is-guest-card': isInvitado}" 
           [style.--custom-bg]="pase.backgroundStyle"
           [style.--custom-img]="pase.eventImg ? 'url(' + pase.eventImg + ')' : 'none'"
           (click)="irAGestionInvitados(pase)"
           data-cy="fair-pass-card">
        
        <div class="card-contrast-overlay"></div>
        
        <div class="stadium-lines-pattern fair-stripes"></div>
        
        <div class="card-split-layout">
          <div class="card-left-identity-panel">
            <div class="card-official-header">
              <div class="club-branding">
                <img src="assets/img/escudo.png" alt="Logo Peña" class="club-badge">
                <div class="club-titles">
                  <h1 class="event-main-title">
                    {{ pase.eventTitle }}
                  </h1>
                  <h2 class="event-subtitle">CONVOCATORIA {{ anioActual }}</h2>
                </div>
              </div>
            </div>

            <div class="card-official-body">
              <div class="fair-frame">
                <img [src]="currentUserData?.foto || 'assets/icons/icon-128.webp'" alt="Foto Usuario">
              </div>
              
              <div class="player-identity">
                <span class="card-role-badge-pillar" [style.background]="isInvitado ? '#e11d48' : '#38bdf8'">
                  {{ (currentUserData?.tipo || 'Socio').toUpperCase() }}
                </span>
                <h2 class="player-name" data-cy="pass-card-user-name">
                  {{ currentUserData?.nombre }}
                </h2>
                <span class="player-document" *ngIf="currentUserData?.dni">DNI: {{ currentUserData?.dni }}</span>
              </div>
            </div>
          </div>

          <div class="card-right-qr-panel" (click)="abrirCodigoQR(pase); $event.stopPropagation()" data-cy="btn-open-qr-modal">
            <div class="qr-embedded-box">
              <img [src]="'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=' + (isInvitado ? pase.id : 'SOCIO:' + currentUserId + ':EVENTO-' + pase.eventId)" alt="QR Mini">
            </div>
            <span class="qr-tap-hint">
              VER QR <ion-icon name="qr-code-outline"></ion-icon>
            </span>
          </div>
        </div>

        <div class="card-official-footer fair-footer-bg">
          
          <ng-container *ngIf="!isInvitado">
            <div class="stadium-stat-box">
              <span class="stat-label">Nº SOCIO</span>
              <span class="stat-value" data-cy="pass-card-socio-num">#{{ currentUserData?.numeroSocio || '1' }}</span>
            </div>
            <div class="stadium-stat-box">
              <span class="stat-label">VALIDEZ</span>
              <span class="stat-value validez-diaria">
                {{ pase.validezTexto || 'ABONO EVENTO' }}
              </span>
            </div>
            <div class="stadium-stat-box" *ngIf="pase.limiteInvitadosPorSocio && pase.limiteInvitadosPorSocio > 0">
              <span class="stat-label">INVITADOS</span>
              <span class="stat-value guest-highlight">
                Gestionar <ion-icon name="arrow-forward-outline"></ion-icon>
              </span>
            </div>
          </ng-container>

          <ng-container *ngIf="isInvitado">
            <div class="stadium-stat-box">
              <span class="stat-label">ANFITRIÓN</span>
              <span class="stat-value guest-highlight">{{ pase.invitedByName || 'Peña Oficial' }}</span>
            </div>
            <div class="stadium-stat-box">
              <span class="stat-label">VALIDEZ</span>
              <span class="stat-value validez-diaria">SOLO HOY</span>
            </div>
          </ng-container>

          <div class="stadium-stat-box">
            <span class="stat-label">ACCESO</span>
            <span class="stat-value acceso-validado">VALIDADO</span>
          </div>
        </div>
      </div>

    </div>

    <ng-template #sinPasesTpl>
      <div class="glass-card empty-warning-card" data-cy="fair-no-pass-assigned">
        <ion-icon name="ticket-outline" class="empty-icon"></ion-icon>
        <h2>No tienes pases activos para hoy</h2>
        <p class="empty-p">
          Confirma tu asistencia en la sección de Eventos para que el sistema genere tus credenciales digitales de acceso.
          {{ isInvitado ? 'O solicita a un socio autorizado que emita una invitación a tu nombre.' : '' }}
        </p>
      </div>
    </ng-template>

  </div>

  <ion-modal [isOpen]="isQrModalOpen" (didDismiss)="cerrarCodigoQR()" data-cy="fair-qr-modal">
    <ng-template>
      <ion-header class="ion-no-border">
        <ion-toolbar style="--background: #070d19; --color: white;">
          <ion-buttons slot="end">
            <ion-button (click)="cerrarCodigoQR()" data-cy="btn-close-qr-modal">
              <ion-icon name="close-outline" style="font-size: 28px; color: white;"></ion-icon>
            </ion-button>
          </ion-buttons>
        </ion-toolbar>
      </ion-header>
      
      <ion-content style="--background: #070d19;">
        <div class="modal-contents" *ngIf="paseSeleccionadoModal">
          <h3>Control de Accesos</h3>
          <p class="modal-event-title">
            {{ paseSeleccionadoModal.eventTitle }}
          </p>
          
          <div class="qr-fullscreen-box" data-cy="qr-fullscreen-container">
            <img [src]="'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + qrPayload" alt="QR Control Acceso">
          </div>
          
          <div class="manual-code-container">
            <span class="manual-code-label">CÓDIGO DE VERIFICACIÓN ALFANUMÉRICO</span>
            <div class="manual-code-value" data-cy="qr-manual-code-text">{{ qrPayload }}</div>
          </div>

          <span class="badge-modal-date" [style.background]="isInvitado ? '#e11d48' : '#ffb703'" [style.color]="isInvitado ? '#ffffff' : '#070d19'">
            {{ isInvitado ? 'INVITACIÓN DIGITAL DE ACCESO' : 'PASE EXCLUSIVO DE ASISTENTE - TEMPORADA ' + anioActual }}
          </span>
        </div>
      </ion-content>
    </ng-template>
  </ion-modal>

</ion-content>
