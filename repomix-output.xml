<file path="src/app/features/auth/pages/login/login.page.html">
<ion-content fullscreen="true" class="login-content" data-cy="login-page">
  <div class="background-logo">
    <img src="assets/img/escudo.png" alt="Escudo">
  </div>

  <div class="login-container">
    <div class="form-card">

      <div class="header-section">
        <div class="logo-circle">
          <img src="assets/img/escudo.png" alt="Logo">
        </div>
        <h2>Bienvenido</h2>
        <p>Accede a tu cuenta de socio</p>
      </div>

      <div class="form-section">
        <ion-item lines="none">
          <ion-input label="Email" labelPlacement="floating" type="email" [(ngModel)]="email"
            placeholder="ejemplo@correo.com" data-cy="input-login-email">
          </ion-input>
        </ion-item>

        <ion-item lines="none">
          <ion-input [type]="showPassword ? 'text' : 'password'" label="Contraseña" labelPlacement="floating"
            [(ngModel)]="password" data-cy="input-login-password">
          </ion-input>
          <ion-button slot="end" fill="clear" (click)="showPassword = !showPassword" class="eye-button"
            data-cy="btn-login-toggle-password">
            <ion-icon [name]="showPassword ? 'eye-off-outline' : 'eye-outline'"></ion-icon>
          </ion-button>
        </ion-item>

        <div class="button-section">
          <ion-button expand="block" (click)="ingresar()" [disabled]="cargando" class="main-button"
            data-cy="btn-login-submit">
            <span *ngIf="!cargando" data-cy="btn-login-text">Entrar</span>
            <ion-spinner *ngIf="cargando" name="crescent" data-cy="login-spinner"></ion-spinner>
          </ion-button>
        </div>
      </div>

    </div>

    <footer class="app-footer-fixed">
      <p>© 2026 ADC Los Locos. Gestión Digital Oficial.</p>
    </footer>
  </div>
</ion-content>
</file>

