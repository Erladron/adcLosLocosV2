            <div class="qr-embedded-box">
              <img [src]="'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=' + (isInvitado ? pase.id : 'SOCIO:' + currentUserId + ':EVENTO-' + pase.eventId)" alt="QR Mini">
            </div>
            <span class="qr-tap-hint">
              VER QR <ion-icon name="qr-code-outline"></ion-icon>
            </span>
          </div>
        </div>

        <div class="card-official-footer fair-footer-bg">
          
          <ng-container *ngIf="!isInvitado">
            <div class="stadium-stat-box">
              <span class="stat-label">Nº SOCIO</span>
              <span class="stat-value" data-cy="pass-card-socio-num">#{{ currentUserData?.numeroSocio || '1' }}</span>
            </div>
            <div class="stadium-stat-box">
              <span class="stat-label">VALIDEZ</span>
              <span class="stat-value validez-diaria">
                {{ pase.validezTexto || 'ABONO EVENTO' }}
              </span>
            </div>
            <div class="stadium-stat-box" *ngIf="pase.limiteInvitadosPorSocio && pase.limiteInvitadosPorSocio > 0">
              <span class="stat-label">INVITADOS</span>
              <span class="stat-value guest-highlight">
                Gestionar <ion-icon name="arrow-forward-outline"></ion-icon>
              </span>
            </div>
          </ng-container>

          <ng-container *ngIf="isInvitado">
            <div class="stadium-stat-box">
              <span class="stat-label">ANFITRIÓN</span>
              <span class="stat-value guest-highlight">{{ pase.invitedByName || 'Peña Oficial' }}</span>
            </div>
            <div class="stadium-stat-box">
              <span class="stat-label">VALIDEZ</span>
              <span class="stat-value validez-diaria">SOLO HOY</span>
