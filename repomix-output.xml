        <ion-icon name="checkmark-circle-outline">
        </ion-icon>

        <span>

          Aprobación

        </span>

      </div>

      <div class="audit-modern-content">

        <div *ngIf="user.aprobadoPorNombre" class="audit-modern-line">

          <ion-icon name="person-outline">
          </ion-icon>

          <span data-cy="audit-aprobacion-by">
            {{ user.aprobadoPorNombre }}
