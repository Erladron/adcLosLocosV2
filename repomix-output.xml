<main class="welcome-wrapper">
  <div class="welcome-card">
    
    <header class="card-header">
      <div class="logo-container">
        <img src="https://firebasestorage.googleapis.com/v0/b/adcloslocos-desa.firebasestorage.app/o/escudo.png?alt=media&token=6b0614fc-9d03-4b73-8c8b-be07e8fabbad" alt="ADC Los Locos" class="club-logo">
      </div>
      <h1>A.C.D. LOS LOCOS</h1>
      <p class="slogan">"Yo no estoy loco, vivo la locura"</p>
    </header>

    <div class="card-content">
      <section class="status-box">
        
        <div *ngIf="loading" class="state-container">
          <div class="spinner-box"></div>
          <p class="subtitle-text">Verificando la seguridad del enlace...</p>
        </div>

        <div *ngIf="!loading && errorMessage && !isSuccess" class="state-container">
          <div class="status-icon icon-error">⚠️</div>
          <h3>Acceso denegado</h3>
          <p class="subtitle-text">{{ errorMessage }}</p>
        </div>

        <div *ngIf="!loading && !errorMessage && !isSuccess" class="form-container">
          <form (ngSubmit)="resetPassword()" #resetForm="ngForm">
            
            <div class="input-wrapper">
              <label class="input-label">Contraseña nueva</label>
              <div class="input-field-container">
                <input 
                  [type]="showPassword ? 'text' : 'password'" 
                  [(ngModel)]="password" 
                  name="password" 
                  placeholder="Escribe tu nueva contraseña" 
                  class="custom-input"
                  required>
                <button type="button" class="eye-btn" (click)="togglePassword()">
                  {{ showPassword ? '🙈' : '👁️' }}
                </button>
              </div>
            </div>

            <div class="input-wrapper">
              <label class="input-label">Confirmar contraseña</label>
              <div class="input-field-container">
                <input 
                  [type]="showRepeatPassword ? 'text' : 'password'" 
                  [(ngModel)]="repeatPassword" 
                  name="repeatPassword" 
                  placeholder="Repite la contraseña" 
                  class="custom-input"
                  required>
                <button type="button" class="eye-btn" (click)="toggleRepeatPassword()">
                  {{ showRepeatPassword ? '🙈' : '👁️' }}
                </button>
              </div>
            </div>

            <div class="btn-container">
              <button 
                type="submit" 
                class="btn-primary full-width-btn" 
                [disabled]="isSubmitting || !password || !repeatPassword">
                {{ isSubmitting ? 'Guardando...' : 'Guardar contraseña' }}
              </button>
            </div>

          </form>
        </div>

        <div *ngIf="isSuccess" class="state-container">
          <div class="status-icon icon-success">✅</div>
          <h3>¡Contraseña guardada!</h3>
          <p class="subtitle-text">
            Tu clave se ha cambiado correctamente. Ya puedes abrir la aplicación de <strong>A.C.D. Los Locos</strong> e iniciar sesión con tus nuevas credenciales.
          </p>
        </div>

      </section>
    </div>

    <footer class="card-footer">
      <p>© 2026 ADC Los Locos. Configuración de Credenciales Seguras.</p>
    </footer>

  </div>
</main>
