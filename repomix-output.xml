<div class="section-card" *ngIf="!mostrarCropper" data-cy="personal-data-card">
  <div class="header-main-row">
    <div class="profile-header">
      <div class="avatar-container circular-profile">
        <img *ngIf="user?.foto" [src]="user.foto" class="profile-avatar" data-cy="profile-avatar-img" />
        <div *ngIf="!user?.foto" class="default-avatar">
          <ion-icon name="person-outline"></ion-icon>
        </div>
