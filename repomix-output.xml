              <ion-icon name="close-outline" style="font-size: 28px; color: white;"></ion-icon>
            </ion-button>
          </ion-buttons>
        </ion-toolbar>
      </ion-header>
      
      <ion-content style="--background: #070d19;">
        <div class="modal-contents" *ngIf="paseSeleccionadoModal">
