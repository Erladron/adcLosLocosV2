  --border-radius: 16px !important;
}

/* ========================================================
   6. MAPBOX SUGGESTIONS (ESTILOS NUEVOS)
======================================================== */
.direccion-container {
  position: relative;
  width: 100%;
}

.mapbox-suggestions {
  position: absolute;
  top: 100%; /* Se coloca justo debajo del input */
  left: 0;
  right: 0;
  z-index: 1000;
  
  /* Estética Glassmorphism combinada con tu tarjeta */
  background: rgba(17, 37, 84, 0.98);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  
  /* Ajustes de margen para solapar un poco con el hueco del ion-item */
  margin-top: -14px;
  margin-bottom: 18px;
  
  max-height: 220px;
  overflow-y: auto;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
