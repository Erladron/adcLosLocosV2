          <p class="modal-event-title">
            {{ paseSeleccionadoModal.eventTitle }}
          </p>
          
          <div class="qr-fullscreen-box" data-cy="qr-fullscreen-container">
            <img [src]="'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + qrPayload" alt="QR Control Acceso">
          </div>
          
