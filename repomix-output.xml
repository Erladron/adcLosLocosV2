    bottom: 20px;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    padding: 8px 24px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    z-index: 25;
  }
}

@keyframes scanLaser {
  0% { top: 5%; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 95%; opacity: 0; }
}

.scan-instructions {
  text-align: center;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.5;
  margin: 30px 20px auto 20px;
}

.manual-entry-console {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  padding: 20px;
  margin-top: 20px;
  z-index: 40;

  .console-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 11px;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: 1px;
    ion-icon { font-size: 14px; }
  }

  .input-group {
    display: flex;
    gap: 12px;
    input {
      flex: 1;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 0 16px;
      color: white;
      font-size: 14px;
      outline: none;
      &:focus { border-color: #38bdf8; }
    }
    .btn-validate {
      background: #ffb703;
      color: #000;
      border: none;
      border-radius: 10px;
      padding: 0 20px;
      font-weight: 800;
      height: 48px;
      &:disabled { background: rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.3); }
    }
  }
}

// ============================================
// 🚀 FIX FULLSCREEN FEEDBACK (FUERA DE LA CONSOLA)
// ============================================
.feedback-fullscreen {
  position: fixed; // Ocupa todo el terminal rompiendo herencias
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
