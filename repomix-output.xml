    background-color: #dc2626 !important; // Rojo chillón masivo
  }

  .feedback-content {
    color: #ffffff;

    ion-icon {
      font-size: 140px;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 38px;
      font-weight: 900;
      letter-spacing: 1.5px;
      margin: 0 0 12px 0;
    }

    p {
      font-size: 20px;
      font-weight: 600;
      opacity: 0.9;
      margin: 0;
    }
