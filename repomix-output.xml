    </ion-item>

    <ion-item class="custom-item" *ngIf="isPortero && (!isEditMode || editing || user.empresa)">
      <ion-label position="stacked">Empresa de Seguridad *</ion-label>
      <ion-input [(ngModel)]="user.empresa" placeholder="Ej. Prosegur, Securitas..." [readonly]="!canEdit || (isEditMode && !editing)" data-cy="input-profile-empresa"></ion-input>
      <ion-icon slot="start" name="shield-checkmark-outline" style="color: #38bdf8; margin-top: 24px;"></ion-icon>
    </ion-item>

    <ion-item class="custom-item" *ngIf="user.telefono || !isEditMode || editing">
      <ion-label position="stacked">Teléfono</ion-label>
      <ion-input type="tel" maxlength="9" [(ngModel)]="user.telefono" [readonly]="!canEdit || (isEditMode && !editing)" data-cy="input-profile-telefono"></ion-input>
    </ion-item>

    <ion-item class="custom-item" *ngIf="user.dni || !isEditMode || editing">
