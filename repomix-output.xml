                <img src="assets/img/escudo.png" alt="Logo Peña" class="club-badge">
                <div class="club-titles">
                  <h1 class="event-main-title">
                    {{ pase.eventTitle }}
                  </h1>
                  <h2 class="event-subtitle">CONVOCATORIA {{ anioActual }}</h2>
                </div>
              </div>
