      <ion-icon slot="start" name="cash-outline" [style.color]="user.cuotaAlCorriente ? '#10b981' : '#ef4444'" style="margin-top: 22px; font-size: 1.4rem;"></ion-icon>
      <ion-label>
        <h4>Estado de la Cuota</h4>
