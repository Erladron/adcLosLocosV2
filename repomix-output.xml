      right: 12px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 16px;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
      
      &:hover {
        transform: scale(1.1);
      }
    }
  }
}

.error-msg-text {
  font-size: 12px;
  color: #e11d48;
  font-weight: 500;
  margin-top: 5px;
  padding-left: 2px;
}

.btn-primary {
  background-color: #1c3f7c;
  color: #ffffff;
  border: none;
  padding: 14px 32px;
  font-size: 14px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 12px rgba(28, 63, 124, 0.2);
  transition: all 0.2s ease-in-out;

  &:hover:not(:disabled) {
    background-color: #15305e;
    transform: translateY(-1px);
    box-shadow: 0 6px 15px rgba(28, 63, 124, 0.3);
  }

  &:active:not(:disabled) {
    transform: translateY(1px);
  }
}

.full-width-btn {
  width: 100%;
  display: block;
  text-align: center;

  &:disabled {
    background-color: #94a3b8 !important;
    cursor: not-allowed;
    box-shadow: none !important;
    transform: none !important;
    opacity: 0.7;
  }
}

// ==========================================
// 3. ADAPTACIONES EXTRAS PARA PASOS Y ESTADOS
// ==========================================

.full-width-container {
  width: 100%;
}

.state-container {
  padding: 15px 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;

  .subtitle-text {
    margin-bottom: 0;
    margin-top: 15px;
  }
}

.status-icon {
  font-size: 48px;
  margin-bottom: 15px;
  line-height: 1;
}

.text-center-error {
  text-align: center;
  margin-bottom: 15px;
  font-size: 13px;
}

// Un spinner CSS puro que encaja con vuestro look sin meter librerías extras
.spinner-box {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(28, 63, 124, 0.1);
  border-left-color: #1c3f7c;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ==========================================================================
   ESTILOS DE CAMPOS DE ENTRADA PREMIUM (WEB-ONBOARDING)
   ========================================================================== */

.input-wrapper {
  display: flex;
  flex-direction: column;
  margin-bottom: 20px; /* Separación perfecta entre bloques de campos */
  text-align: left;    /* Alineación limpia de etiquetas */
  
  .input-label {
    font-size: 13px;
    font-weight: 600;
    color: #444444;
    margin-bottom: 6px;
  }
}

.input-field-container {
  position: relative;
  display: flex;
  align-items: center;
  background: #f9fafb;       /* Gris claro premium de onboarding */
  border: 1.5px solid #e5e7eb; /* Borde sutil redondeado */
  border-radius: 10px;
  padding: 2px 14px;
  transition: border-color 0.2s, box-shadow 0.2s;

  /* Efecto foco azul idéntico al registro */
  &:focus-within {
    border-color: #3880ff;
    box-shadow: 0 0 0 3px rgba(56, 128, 255, 0.1);
  }

  .custom-input {
    width: 100%;
    border: none !important;  /* Eliminamos el borde cuadrado feo de HTML */
    background: transparent !important;
    padding: 12px 0;
    font-size: 15px;
    color: #1f2937;
    outline: none !important;
  }

  .eye-btn {
    background: transparent;
    border: none;
    font-size: 18px;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    outline: none;
    
    &:hover {
      opacity: 0.8;
    }
  }
}

/* Margen superior para despegar el botón del último input */
.btn-container {
  margin-top: 32px; 
  width: 100%;
}
