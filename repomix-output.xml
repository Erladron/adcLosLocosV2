        @if (mostrarSugerencias && sugerencias.length > 0) {
          <ion-list class="mapbox-suggestions" data-cy="profile-address-suggestions">
            @for (sug of sugerencias; track sug.id || sug.name) {
              <ion-item button (mousedown)="$event.preventDefault()" (click)="seleccionarDireccion(sug)" data-cy="profile-address-suggestion-item">
                <ion-label>
                  <h2 class="sug-title">{{ sug.name }}</h2>
                  <p class="sug-subtitle">{{ sug.place_formatted }}</p>
                </ion-label>
              </ion-item>
            }
          </ion-list>
        }
      </div>

      <ion-item class="custom-item" *ngIf="user.detallesDireccion || !isEditMode || editing">
        <ion-label position="stacked">Piso, Puerta, Escalera (Opcional)</ion-label>
        <ion-input [(ngModel)]="user.detallesDireccion" placeholder="Ej. 3º B, Bloque 2..." [readonly]="!canEdit || (isEditMode && !editing)" data-cy="input-profile-detalles-direccion"></ion-input>
      </ion-item>
      <ion-item class="custom-item" *ngIf="user.profesion || !isEditMode || editing">
        <ion-label position="stacked">Profesión</ion-label>
        <ion-input [(ngModel)]="user.profesion" placeholder="Ej. Carpintero, Abogado..." [readonly]="!canEdit || (isEditMode && !editing)" data-cy="input-profile-profesion"></ion-input>
      </ion-item>
    </ng-container>

    <div class="privacy-section" *ngIf="!simpleMode && !isPortero">
      <h3 class="privacy-title">
        <ion-icon name="lock-closed-outline"></ion-icon> Privacidad en el directorio
      </h3>
      <p class="privacy-subtitle">Controla qué datos pueden ver otros socios activos de la peña.</p>
      <ion-item class="privacy-toggle-item" lines="none">
        <ion-label><h4>Visibilidad del Teléfono</h4><p>Permitir que otros socios vean mi número.</p></ion-label>
        <ion-toggle slot="end" [(ngModel)]="user.publicarTelefono" [disabled]="!canEdit || (isEditMode && !editing)" data-cy="toggle-profile-privacy-phone"></ion-toggle>
      </ion-item>
      <ion-item class="privacy-toggle-item" lines="none">
        <ion-label><h4>Visibilidad del Email</h4><p>Permitir que otros socios vean mi correo.</p></ion-label>
        <ion-toggle slot="end" [(ngModel)]="user.publicarEmail" [disabled]="!canEdit || (isEditMode && !editing)" data-cy="toggle-profile-privacy-email"></ion-toggle>
      </ion-item>
    </div>
  </div>
</div>

<div class="section-card" *ngIf="mostrarCropper && (internalImageEvent || internalImageBase64)" data-cy="cropper-card-panel">
  <div class="cropper-integrated-layout">
    <div class="cropper-sidebar-left">
      <button class="svg-zoom-btn" (click)="zoomIn()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg></button>
      <button class="svg-zoom-btn" (click)="zoomOut()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg></button>
    </div>
    <div class="cropper-center-stage">
      <image-cropper class="custom-cropper" [imageChangedEvent]="internalImageEvent" [imageBase64]="internalImageBase64" [maintainAspectRatio]="true" [aspectRatio]="1 / 1" [resizeToWidth]="300" [cropperMinWidth]="100" [onlyScaleDown]="true" [roundCropper]="true" [containWithinAspectRatio]="true" [transform]="transform" [imageQuality]="90" format="jpeg" (imageCropped)="onImageCropped($event)"></image-cropper>
    </div>
    <div class="cropper-bottom-actions">
      <ion-button class="action-btn-glass apply" shape="round" (click)="onAceptarRecorte()" data-cy="btn-cropper-accept"><ion-icon slot="icon-only" name="checkmark-outline"></ion-icon></ion-button>
      <ion-button class="action-btn-glass cancel" shape="round" (click)="cancelCropper.emit()" data-cy="btn-cropper-cancel"><ion-icon slot="icon-only" name="close-outline"></ion-icon></ion-button>
    </div>
  </div>
</div>
