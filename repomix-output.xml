  background-color: #1c3f7c;
  color: #ffffff;
  border: none;
  padding: 14px 32px;
  font-size: 14px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 12px rgba(28, 63, 124, 0.2);
  transition: all 0.2s ease-in-out;

  &:hover:not(:disabled) {
    background-color: #15305e;
    transform: translateY(-1px);
    box-shadow: 0 6px 15px rgba(28, 63, 124, 0.3);
  }

  &:active:not(:disabled) {
    transform: translateY(1px);
  }
}

// Modificador del botón para hacerlo expandible al 100%
.full-width-btn {
  width: 100%;
  display: block;
  text-align: center;

  &:disabled {
    background-color: #94a3b8 !important;
    cursor: not-allowed;
    box-shadow: none !important;
    transform: none !important;
    opacity: 0.7;
  }
}
