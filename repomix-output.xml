      data-cy="audit-card-invitacion">

      <div class="audit-modern-title">

        <ion-icon name="mail-open-outline">
        </ion-icon>

        <span>

          Invitación

        </span>

      </div>

      <div class="audit-modern-content">

        <div *ngIf="user.invitadoPorNombre" class="audit-modern-line">

          <ion-icon name="person-outline">
          </ion-icon>

          <span data-cy="audit-invitacion-by">
            {{ user.invitadoPorNombre }}
          </span>

        </div>

