<file path="src/app/features/events/pages/events/events.page.html">
<app-page-header title="Gestión de Eventos" [showMenu]="true" [showBack]="true" data-cy="page-header"></app-page-header>

<ion-content fullscreen="true" class="home-content" data-cy="events-page-content">

  <div class="home-container unified-events-container">

    <!-- 🎛️ FILTROS POR TIPO DE EVENTO (ARRIBA DEL TODO, BAJO EL HEADER) -->
    <ion-segment [scrollable]="true" [value]="currentFilter" (ionChange)="setFilter($event.detail.value)" mode="md"
      class="custom-scroll-segment" data-cy="events-filter-segment">
      <ion-segment-button value="todos" data-cy="filter-btn-todos"><ion-label>Todos</ion-label></ion-segment-button>
      <ion-segment-button value="asamblea" data-cy="filter-btn-asambleas"><ion-label>Asambleas</ion-label></ion-segment-button>
      <ion-segment-button value="comida" data-cy="filter-btn-comidas"><ion-label>Comidas</ion-label></ion-segment-button>
      <ion-segment-button value="quedada" data-cy="filter-btn-quedadas"><ion-label>Quedadas</ion-label></ion-segment-button>
      <ion-segment-button value="feria" data-cy="filter-btn-feria"><ion-label>Feria</ion-label></ion-segment-button>
    </ion-segment>

    <!-- 📆 BLOQUE CALENDARIO: OCUPANDO TODO EL ANCHO CON SEMANA EN LUNES (first-day-of-week="1") -->
    <div class="glass-card calendar-dashboard-card full-width-card">
      <img src="assets/img/escudo.png" alt="Escudo Peña" class="calendar-watermark-logo">

      <div class="calendar-inline-header">
        <ion-icon name="calendar-outline"></ion-icon>
        <h2>Agenda de la Peña</h2>
      </div>

      <ion-datetime 
        presentation="date" 
        locale="es-ES" 
        size="cover"
        first-day-of-week="1"
        [value]="selectedDate"
        [highlightedDates]="highlightedDates"
        (ionChange)="onDateChanged($event)"
        class="peña-integrated-datetime">
      </ion-datetime>
    </div>

    <!-- 📋 LISTADO MINIMALISTA DE EVENTOS (SÓLO TÍTULO SOBRE FONDO) -->
    <div class="events-list-container" *ngIf="filteredEvents$ | async as events; else loadingTpl" data-cy="events-list-wrapper">

      <div class="glass-card empty-warning-card" *ngIf="events.length === 0" data-cy="events-empty-warning">
        <ion-icon name="alert-circle-outline"></ion-icon>
        <p>No hay convocatorias para esta fecha o categoría.</p>
      </div>

      <!-- Tarjeta interactiva estilizada (Al hacer clic redirige al detalle) -->
      <div *ngFor="let event of events" [routerLink]="['/events', event.id]" class="glass-card event-minimal-card" data-cy="event-card"
        [ngStyle]="{
          'background-image': 'linear-gradient(rgba(13, 27, 62, 0.65), rgba(10, 20, 45, 0.85)), url(' + (event.imageUrl || 'assets/img/events-construction.png') + ')'
        }">
        <div class="minimal-card-body">
          <div class="event-type-icon-wrapper-mini">
            <ion-icon [name]="getIconForType(event.type)"></ion-icon>
          </div>
          <h2 class="event-minimal-title" data-cy="event-title-text">{{ event.title }}</h2>
          <ion-icon name="chevron-forward-outline" class="arrow-link-icon"></ion-icon>
        </div>
      </div>

    </div>

    <ng-template #loadingTpl>
      <div class="glass-card loading-card-placeholder">
        <p>Sincronizando agenda...</p>
      </div>
    </ng-template>

    <button routerLink="/events/new" class="peña-fab-btn-native" *ngIf="isAdmin" data-cy="btn-create-event-fab">
      <ion-icon name="add"></ion-icon>
    </button>

  </div>
</ion-content>
</file>

<file path="src/app/features/home/pages/home/home.page.html">
<app-page-header title="Inicio" [showMenu]="true" data-cy="page-header">
</app-page-header>

<ion-content fullscreen="true" class="home-content" data-cy="home-page-content">

  <div class="background-logo">
    <img src="assets/img/escudo.png" alt="Escudo">
  </div>

  <div class="home-container">

    <div class="welcome-section">
      <div>
        <h1 data-cy="welcome-user-title">
          Hola, {{ currentUser?.nombre || 'Usuario' }} 👋
        </h1>
        <p>Bienvenido a A.C.D. Los Locos</p>
      </div>
    </div>

    <div class="peña-membership-card" 
         [ngClass]="currentUser?.tipo" 
         (click)="irAPerfil(currentUser?.id)" 
         style="cursor: pointer;"
         data-cy="home-profile-card">

      <div class="card-geometric-line line-primary"></div>
      <div class="card-geometric-line line-secondary"></div>

      <div class="card-header-corporate">
        <div class="header-left">
          <span class="club-title-text">A.C.D. LOS LOCOS</span>

          <span class="card-type-subtitle"
            *ngIf="currentUser?.tipo === 'socio' || currentUser?.tipo === 'directiva'">CARNET DE SOCIO</span>
          <span class="card-type-subtitle" *ngIf="currentUser?.tipo === 'administrador'">CREDENCIAL DE STAFF</span>
          <span class="card-type-subtitle" *ngIf="currentUser?.tipo === 'invitado'">PASE DE INVITADO</span>
        </div>

        <span class="seniority-badge-text" *ngIf="currentUser?.tipo === 'socio' || currentUser?.tipo === 'directiva'">
          SOCIO DESDE {{ currentUser?.antiguedad || '2026' }}
        </span>
        <span class="seniority-badge-text admin-badge"
          *ngIf="currentUser?.tipo === 'admin' || currentUser?.tipo === 'administrador'">
          SISTEMA S.O.
        </span>
        <span class="seniority-badge-text invitado-badge" *ngIf="currentUser?.tipo === 'invitado'">
          ACCESO LIMITADO
        </span>
      </div>

      <div class="card-body-corporate">

        <div class="avatar-block">
          <img *ngIf="currentUser?.foto" [src]="currentUser?.foto" data-cy="home-profile-avatar-img"
            class="photo-render">
          <div *ngIf="!currentUser?.foto" class="photo-render-placeholder">
            <ion-icon name="person-outline"></ion-icon>
          </div>
        </div>

        <div class="details-block">
          <div class="data-row-corporate">
            <span class="data-label">Usuario</span>
            <strong class="data-value-strong" data-cy="home-info-nombre">{{ currentUser?.nombre }}</strong>
          </div>

          <div class="data-subgrid">
            <div class="data-row-corporate" *ngIf="currentUser?.tipo === 'socio' || currentUser?.tipo === 'directiva'">
              <span class="data-label">Nº Socio</span>
              <span class="data-value" data-cy="home-info-socio-num"># {{ currentUser?.numeroSocio || '--' }}</span>
            </div>

            <div class="data-row-corporate">
              <span class="data-label">Categoría</span>
              <span class="data-value text-uppercase" data-cy="home-info-rol">{{ currentUser?.tipo | uppercase }}</span>
            </div>
          </div>
        </div>

        <div class="shield-block">
          <img src="assets/img/escudo.png" alt="Escudo Peña" class="integrated-shield-img" />
        </div>

      </div>

      <div class="card-footer-corporate">
        <div class="status-pill active">
          <span class="status-dot"></span>
          <span *ngIf="currentUser?.tipo === 'socio' || currentUser?.tipo === 'directiva'">MIEMBRO ACTIVO</span>
          <span *ngIf="currentUser?.tipo === 'administrador'">ADMINISTRADOR</span>
          <span *ngIf="currentUser?.tipo === 'invitado'">VALIDADO</span>
        </div>
        <ion-icon name="create-outline" class="edit-icon-card"></ion-icon>
      </div>

    </div>

    <div class="section-title">
      Accesos rápidos
    </div>

    <div class="quick-grid">

      <div *ngIf="currentUser?.tipo !== 'invitado'" class="quick-card glass-card" (click)="irAUsuarios()"
        data-cy="quick-card-usuarios">
        <div class="quick-icon">
          <ion-icon name="people-outline"></ion-icon>
        </div>
        <div class="quick-info">
          <h3>Usuarios</h3>
          <p>Gestiona usuarios</p>
        </div>
        <ion-icon name="chevron-forward-outline" class="quick-arrow"></ion-icon>
      </div>

      <div class="quick-card glass-card" (click)="irAEventos()" data-cy="quick-card-eventos">
        <div class="quick-icon">
          <ion-icon name="calendar-outline"></ion-icon>
        </div>
        <div class="quick-info">
          <h3>Eventos</h3>
          <p>Consulta eventos</p>
        </div>
        <ion-icon name="chevron-forward-outline" class="quick-arrow"></ion-icon>
      </div>

    </div>

  </div>
</ion-content>
</file>

<file path="src/app/features/users/pages/gest-user/gest-user.page.scss">
/* =========================================
   PAGE
========================================= */

.users-content {

  --background:
    linear-gradient(180deg,
      #123d92 0%,
      #0d327c 100%);

  position: relative;

  overflow: hidden;

}

/* =========================================
   BACKGROUND LOGO
========================================= */

.background-logo {

  position: fixed;

  inset: 0;

  display: flex;

  justify-content: center;

  align-items: center;

  pointer-events: none;

  opacity: 0.08;

  z-index: 0;

}

.background-logo img {

  width: 80%;

  max-width: 500px;

}

/* =========================================
   SEARCH
========================================= */

.search-container {

  position: relative;

  z-index: 2;

  padding:
    18px 16px 8px;

}

.custom-searchbar {

  --background:
    rgba(255, 255, 255, 0.12); // Un pelín más opaco el fondo para asentar el texto

  --border-radius:
    22px;

  --box-shadow:
    none;

  // 🔍 ADAPTACIÓN DE ALTO CONTRASTE HUMANO:
  --placeholder-color:
    rgba(255, 255, 255, 0.70); // El texto de "Buscar usuario..." se lee mucho más claro

  --color:
    #ffffff; // Las letras que escribe el usuario pasan a ser blanco puro e intenso

  --icon-color:
    #ffffff; // 💡 NUEVO: Fuerza a que la lupa (y el botón de borrar) brillen en blanco puro

  backdrop-filter:
    blur(10px);

}
/* =========================================
   SEGMENT
========================================= */

.users-segment {

  width: 100%;

  margin:
    10px 0 18px;

  border-radius:
    22px;

  background:
    rgba(255, 255, 255, 0.08);

  backdrop-filter:
    blur(12px);

  border:
    1px solid rgba(255, 255, 255, 0.06);

  overflow-x: auto;

  overflow-y: hidden;

  scrollbar-width: none;

  -ms-overflow-style: none;

}

.users-segment::-webkit-scrollbar {

  display: none;

}

.users-segment ion-segment-button {

  --color:
    rgba(255, 255, 255, 0.7);

  --color-checked:
    #4da3ff;

  --indicator-color:
    #1f7cff;

  min-height:
    54px;

  min-width:
    150px;

  font-weight:
    600;

  text-transform:
    uppercase;

  letter-spacing:
    0.5px;

  white-space: nowrap;

  flex-shrink: 0;

}

/* =========================================
   USERS CONTAINER
========================================= */

.users-container {

  position: relative;

  z-index: 2;

  display: flex;

  flex-direction: column;

  gap: 14px;

  padding:
    0 16px 100px;

}

/* =========================================
   USER CARD
========================================= */

.user-card {

  display: flex;

  align-items: center;

  gap: 14px;

  width: 100%;

  padding:
    14px;

  border-radius:
    24px;

  background:
    rgba(255, 255, 255, 0.14);

  border:
    1px solid rgba(255, 255, 255, 0.12);

  backdrop-filter:
    blur(18px);

  box-shadow:
    0 8px 24px rgba(0, 0, 0, 0.16);

  transition:
    all 0.25s ease;

}

.user-card:active {

  transform:
    scale(0.99);

}

/* =========================================
   PENDING CARD
========================================= */

.pending-card {

  border:
    1px solid rgba(255, 208, 0, 0.28);

}

/* =========================================
   AVATAR
========================================= */

.user-avatar-container {

  flex-shrink: 0;

}

.user-avatar,
.default-avatar {

  width: 64px;

  height: 64px;

  border-radius: 50%;

  object-fit: cover;

}

.user-avatar {

  border:
    2px solid rgba(255, 255, 255, 0.25);

}

.default-avatar {

  display: flex;

  align-items: center;

  justify-content: center;

  background:
    rgba(255, 255, 255, 0.12);

  color:
    rgba(255, 255, 255, 0.85);

  font-size:
    28px;

}

/* =========================================
   USER INFO
========================================= */

.user-info-mini {

  flex: 1;

  min-width: 0;

}

.user-info-mini h2 {

  margin: 0;

  color:
    #ffffff;

  font-size:
    22px;

  font-weight:
    700;

}

// ⚙️ OPTIMIZACIÓN MÓVIL HORIZONTAL: Layout elástico e inline para evitar tarjetas estiradas
.user-subinfo {

  display: flex;

  align-items: center;

  gap: 10px; // Espacio uniforme entre los elementos informativos

  margin-top: 6px;

  flex-wrap: wrap; // Rompe de línea seguro solo si el dispositivo es extremadamente pequeño

}

/* ==========================================================================
   🔥 NUEVO MOTOR DE ESTILOS HORIZONTALES DE ALTO CONTRASTE CONTRA FONDO AZUL
   ========================================================================== */

.meta-item {
  display: inline-flex;
  align-items: center;
  gap: 4px; // Separación interna muy ajustada entre el icono y su texto
  font-size: 13px;
  
  ion-icon {
    font-size: 13px;
    flex-shrink: 0; // Evita que Ionic encoja el icono si el texto es largo
  }
}

// 💼 PROFESIÓN: Subida a celeste brillante de alta visibilidad
.profesion-item {
  color: #64b5f6;
  font-weight: 600;
  
  ion-icon {
    color: #64b5f6;
  }
}

// 📞 TELÉFONO: Subido a blanco translúcido puro para contraste impecable
.telefono-item {
  color: rgba(255, 255, 255, 0.88);
  font-weight: 500;
  
  ion-icon {
    color: rgba(255, 255, 255, 0.85);
  }
}

// 🔒 PRIVADO: Tono grisáceo atenuado pero legible para el estado oculto
.privado-item {
  color: rgba(255, 255, 255, 0.45);
  
  .sub-italic {
    font-style: italic;
  }
}

.meta-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

// Clase heredada antigua de compatibilidad
.telefono-text {
  color: rgba(255, 255, 255, 0.82);
  font-size: 14px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* =========================================
   BADGES
========================================= */

.tipo-badge,
.status-badge {

  display: inline-flex;

  align-items: center;

  justify-content: center;

  padding:
    6px 12px;

  border-radius:
    999px;

  font-size:
    13px;

  font-weight:
    700;

}

.tipo-badge {

  background:
    rgba(255, 255, 255, 0.12);

  color:
    #ffffff;

}

.tipo-badge.pending {

  background:
    rgba(255, 196, 0, 0.16);

  border:
    1px solid rgba(255, 196, 0, 0.25);

  color:
    #ffd24d;

}

.status-badge.approved {

  background:
    rgba(34, 197, 94, 0.16);

  border:
    1px solid rgba(34, 197, 94, 0.28);

  color:
    #4ade80;

}

.dot {

  color:
    rgba(255, 255, 255, 0.45);

}

/* =========================================
   STATUS CONTAINER
========================================= */

.status-container {

  margin-left: auto;

}

/* =========================================
   ARROW
========================================= */

.arrow-icon {

  color:
    rgba(255, 255, 255, 0.55);

  font-size:
    20px;

}

/* =========================================
   APPROVAL ACTIONS
========================================= */

.approval-actions {

  display: flex;

  align-items: center;

  justify-content: flex-end;

  gap: 8px;

  margin-left: auto;

  flex-shrink: 0;

}

/* =========================================
   ACTION BUTTON
========================================= */

.action-btn {

  width: 34px;

  height: 34px;

  min-width: 34px;

  min-height: 34px;

  border-radius: 50%;

  border: none;

  padding: 0;

  display: flex;

  align-items: center;

  justify-content: center;

  cursor: pointer;

  transition:
    all 0.25s ease;

  backdrop-filter:
    blur(12px);

  box-shadow:
    0 4px 14px rgba(0, 0, 0, 0.18);

}

.action-btn ion-icon {

  font-size: 16px;

}

/* =========================================
   APPROVE
========================================= */

.approve-btn {

  background:
    rgba(34, 197, 94, 0.18);

  border:
    1px solid rgba(34, 197, 94, 0.35);

  color:
    #4ade80;

}

.approve-btn:hover {

  transform:
    scale(1.05);

  box-shadow:
    0 0 18px rgba(34, 197, 94, 0.35);

}

/* =========================================
   REJECT
========================================= */

.reject-btn {

  background:
    rgba(239, 68, 68, 0.14);

  border:
    1px solid rgba(239, 68, 68, 0.28);

  color:
    #f87171;

}

.reject-btn:hover {

  transform:
    scale(1.05);

  box-shadow:
    0 0 18px rgba(239, 68, 68, 0.30);

}

/* =========================================
   FAB
========================================= */

.fab-safe-area {

  margin-bottom:
    env(safe-area-inset-bottom);

}

ion-fab-button {

  --background:
    linear-gradient(135deg,
      #2f7cff,
      #1f5edb);

  --box-shadow:
    0 10px 24px rgba(0, 0, 0, 0.25);

}

/* =========================================
   MOBILE RESPONSIVE RESPALDO
========================================= */

@media (max-width: 480px) {

  .user-card {

    padding:
      12px;

    gap:
      12px;

  }

  .user-avatar,
  .default-avatar {

    width: 56px;

    height: 56px;

  }

  .user-info-mini h2 {

    font-size:
      18px;

  }

  .meta-text {
    max-width: 110px; // Recorte elástico para que quepa todo de forma nativa en pantallas pequeñas
  }

  .telefono-text {

    max-width:
      120px;

  }

}

/* =========================================
   INVITE META
========================================= */

.invite-meta {

  margin-top: 6px;

  font-size: 12px;

  color:
    rgba(255, 255, 255, 0.55);

  line-height: 1.4;

}

.invite-meta strong {

  color:
    rgba(255, 255, 255, 0.82);

  font-weight:
    600;

}

/* =========================================
   SEGMENT WRAPPER
========================================= */

.users-segment-wrapper {

  padding:
    0 16px;

}

// ========================================
// MOBILE SEGMENT SCROLL FIX
// ========================================

.user-segment {

  overflow-x: auto;

  overflow-y: hidden;

  scrollbar-width: none;

  -ms-overflow-style: none;

  padding-bottom: 4px;

}

.user-segment::-webkit-scrollbar {

  display: none;

}

.user-segment ion-segment {

  display: flex;

  width: max-content;

  min-width: 100%;

}

.user-segment ion-segment-button {

  min-width: max-content;

  padding-left: 20px;

  padding-right: 20px;

  flex: 0 0 auto;
}
