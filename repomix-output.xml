  .logo-circle {
    background: rgba(255, 255, 255, 0.9);
    width: 90px;
    height: 90px;
    border-radius: 50%;
    margin: 0 auto 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 10px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    
    img {
      width: 100%;
      object-fit: contain;
    }
  }

  h2 {
    color: white;
    font-weight: 700;
    margin: 0;
    font-size: 28px;
  }

  p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    margin-top: 5px;
  }
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 16px;

  ion-item {
    --background: rgba(255, 255, 255, 0.08);
    --border-radius: 12px;
    --color: white;
    --highlight-color-focused: white;
    margin-bottom: 4px;

    ion-input {
      --color: white;
      font-size: 15px;
      font-weight: 500;
    }

    .eye-button {
      --color: rgba(255, 255, 255, 0.6);
      margin: 0;
      height: 100%;
      font-size: 20px;
    }
  }
}

.button-section {
  margin-top: 15px;

  .main-button {
    --background: white;
    --color: #0b2f73;
    --border-radius: 14px;
    font-weight: 700;
    font-size: 16px;
    height: 50px;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    margin: 0;

    span {
      font-weight: 700;
    }

    ion-spinner {
      --color: #0b2f73;
    }
  }
}

/* ==========================================================================
   PIE DE PÁGINA NATIVO PROFESIONAL (EVITA COLISIONES CON EL TECLADO)
   ========================================================================== */
.app-footer-fixed {
  text-align: center;
  width: 100%;
  padding: 10px 0;
  z-index: 10;
  
  // Si la pantalla tiene altura suficiente (móvil normal/grande), se ancla abajo
  @media (min-height: 600px) {
    position: absolute;
    bottom: 20px;
    left: 0;
  }

  p {
    color: rgba(255, 255, 255, 0.45); /* Tono semi-translúcido muy elegante */
    font-size: 13px;
    margin: 0;
    letter-spacing: 0.3px;
    font-weight: 400;
  }
}
