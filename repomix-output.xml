    data: {
      roles: [
        UserRole.SOCIO,
        UserRole.DIRECTIVA,
        UserRole.ADMINISTRADOR
      ]
    },
    loadComponent: () => import('@users/pages/gest-user/gest-user.page').then(m => m.GestUserPage)
  },
  {
    path: 'user-detail',
    canActivate: [authGuard, roleGuard],
    data: {
      roles: [
        UserRole.SOCIO,
        UserRole.DIRECTIVA,
